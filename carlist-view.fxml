<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.carrental.CarListController">

    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <Label text="Available Cars"
           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchDateField"
                   promptText="Search by date (YYYY-MM-DD)"
                   style="-fx-font-size: 13px; -fx-pref-width: 250px;"/>
        <Button text="Search"
                onAction="#handleSearch"
                style="-fx-background-color: #4A90D9; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-pref-height: 35px; -fx-cursor: hand;"/>
        <Button text="Show All"
                onAction="#handleShowAll"
                style="-fx-background-color: #888888; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-pref-height: 35px; -fx-cursor: hand;"/>
    </HBox>

    <Label fx:id="statusLabel"
           text=""
           style="-fx-text-fill: red; -fx-font-size: 12px;"/>

    <ListView fx:id="carListView"
              style="-fx-font-size: 13px;"
              prefHeight="350"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="View Details"
                onAction="#handleViewDetails"
                style="-fx-background-color: #4A90D9; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-pref-width: 150px; -fx-pref-height: 35px;
                       -fx-cursor: hand;"/>
        <Button text="Add to Cart"
                onAction="#handleAddToCart"
                style="-fx-background-color: #FFD700; -fx-text-fill: #333333;
                       -fx-font-size: 13px; -fx-pref-width: 150px; -fx-pref-height: 35px;
                       -fx-cursor: hand;"/>
        <Button text="Log Out"
                onAction="#handleLogOut"
                style="-fx-background-color: #cc0000; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-pref-width: 100px; -fx-pref-height: 35px;
                       -fx-cursor: hand;"/>
    </HBox>

</VBox>