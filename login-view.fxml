<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.carrental.LoginController">

    <padding>
        <Insets top="60" right="80" bottom="60" left="80"/>
    </padding>

    <Label text="Car Rental System"
           style="-fx-font-size: 28px; -fx-font-weight: bold;"/>

    <Label text="Welcome! Please log in or register."
           style="-fx-font-size: 14px; -fx-text-fill: #666666;"/>

    <Label text=""/>

    <Label text="Email" style="-fx-font-size: 13px;"/>
    <TextField fx:id="emailField"
               promptText="Enter your email"
               style="-fx-font-size: 13px; -fx-pref-width: 300px;"/>

    <Label text="Password" style="-fx-font-size: 13px;"/>
    <PasswordField fx:id="passwordField"
                   promptText="Enter your password"
                   style="-fx-font-size: 13px; -fx-pref-width: 300px;"/>

    <Label fx:id="errorLabel"
           text=""
           style="-fx-text-fill: red; -fx-font-size: 12px;"/>

    <Button fx:id="loginButton"
            text="Log In"
            onAction="#handleLogin"
            style="-fx-background-color: #4A90D9; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-pref-width: 300px; -fx-pref-height: 40px;
                   -fx-cursor: hand;"/>

    <Button fx:id="registerButton"
            text="Register New Account"
            onAction="#handleRegister"
            style="-fx-background-color: #FFD700; -fx-text-fill: #333333;
                   -fx-font-size: 14px; -fx-pref-width: 300px; -fx-pref-height: 40px;
                   -fx-cursor: hand;"/>

</VBox>